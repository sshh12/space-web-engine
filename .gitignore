node_modules/
.env
shots/
shots-*/
__pycache__/
*.pyc

# cache/ — disposable generated blobs keyed by (recipeHash, bodyId), plus the
# manifest (a cache-internal staleness index, NOT a committed contract; a pin
# would fight JIT system generation). Re-derivable from the recipe; determinism
# is proven by test/assets-test.mjs, not by a committed hash file.
cache/

# harness run outputs stay local; only the small committed baselines
# (baseline/metrics.json, baseline/golden.json) are tracked.
harness/out/
harness/e2e-out/
harness/nav-out/
harness/editor-out/
harness/smallbody-out/
harness/baseline/full/
harness/baseline/stills/
harness/baseline/records.json
