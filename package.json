{
  "name": "space-web-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Deterministic procedural planet renderer -> SpaceEngine x KSP-class game engine (space-to-surface, multiplayer).",
  "scripts": {
    "serve": "node harness/serve.mjs",
    "bench": "node harness/bench.mjs",
    "bench:motion": "node harness/motion.mjs",
    "shots": "node harness/shots.mjs",
    "profile": "node harness/profile.mjs",
    "typecheck": "tsc --noEmit",
    "test": "node test/all.mjs",
    "test:e2e": "node harness/e2e.mjs",
    "test:nav": "node test/nav-test.mjs",
    "test:nav:e2e": "node harness/nav-e2e.mjs",
    "test:warp": "node test/warp-test.mjs",
    "test:warp:e2e": "node harness/warp-e2e.mjs",
    "test:editor": "node test/editor-test.mjs",
    "test:editor:e2e": "node harness/editor-e2e.mjs",
    "test:smallbody": "node test/smallbody-test.mjs",
    "test:smallbody:e2e": "node harness/smallbody-e2e.mjs",
    "test:golden": "node harness/golden.mjs --verify",
    "test:golden:full": "node harness/golden.mjs --capture-full",
    "test:contract": "node test/contract-test.mjs",
    "test:global": "node test/global-test.mjs",
    "test:reload": "node test/reload-test.mjs",
    "test:rock": "node test/rock-test.mjs",
    "test:strata": "node test/strata-test.mjs",
    "test:tect": "node test/tect-test.mjs",
    "test:climate": "node test/climate-test.mjs",
    "test:mesh": "node test/mesh-test.mjs",
    "test:cloud": "node test/cloud-test.mjs",
    "test:figure": "node test/figure-test.mjs",
    "test:ring": "node test/ring-test.mjs",
    "test:cryo": "node test/cryo-test.mjs"
  },
  "dependencies": {
    "puppeteer": "^23.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2"
  }
}
